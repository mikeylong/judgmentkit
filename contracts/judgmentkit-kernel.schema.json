{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JudgmentKit Activity Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "source_model",
    "quality_order",
    "surface_types",
    "activity_model",
    "interaction_contract",
    "disclosure_policy",
    "implementation_contract",
    "evaluation"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "source_model": {
      "type": "string",
      "const": "fresh_start"
    },
    "quality_order": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string"
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topology_policy"],
      "properties": {
        "id": {
          "type": "string",
          "const": "workflow.ai-ui-generation"
        },
        "topology_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_topologies",
            "preferred_default",
            "work_units_guidance",
            "surface_set_guidance",
            "stepper_eligibility"
          ],
          "properties": {
            "allowed_topologies": {
              "type": "array",
              "items": { "type": "string" }
            },
            "preferred_default": { "type": "string" },
            "work_units_guidance": {
              "type": "array",
              "items": { "type": "string" }
            },
            "surface_set_guidance": {
              "type": "array",
              "items": { "type": "string" }
            },
            "stepper_eligibility": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "policy",
                "allowed_when",
                "not_allowed_when",
                "failure_signals"
              ],
              "properties": {
                "policy": { "type": "string", "const": "strong_intent" },
                "allowed_when": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "not_allowed_when": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "failure_signals": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator-review-ui": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pattern_id",
            "applies_when_most_true",
            "do_not_use_when",
            "guardrails",
            "review_criteria",
            "test_scenarios"
          ],
          "properties": {
            "pattern_id": { "type": "string", "const": "operator-review" },
            "applies_when_most_true": { "type": "array", "items": { "type": "string" } },
            "do_not_use_when": { "type": "array", "items": { "type": "string" } },
            "guardrails": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "guidance"],
                "properties": {
                  "id": { "type": "string" },
                  "guidance": { "type": "string" }
                }
              }
            },
            "review_criteria": { "type": "array", "items": { "type": "string" } },
            "test_scenarios": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "surface_types": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketing",
        "workbench",
        "operator_review",
        "form_flow",
        "dashboard_monitor",
        "content_report",
        "setup_debug_tool",
        "conversation"
      ],
      "properties": {
        "marketing": { "$ref": "#/$defs/surfaceType" },
        "workbench": { "$ref": "#/$defs/surfaceType" },
        "operator_review": { "$ref": "#/$defs/surfaceType" },
        "form_flow": { "$ref": "#/$defs/surfaceType" },
        "dashboard_monitor": { "$ref": "#/$defs/surfaceType" },
        "content_report": { "$ref": "#/$defs/surfaceType" },
        "setup_debug_tool": { "$ref": "#/$defs/surfaceType" },
        "conversation": { "$ref": "#/$defs/surfaceType" }
      }
    },
    "activity_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_supported",
        "participants",
        "objective",
        "outcomes",
        "existing_tools_artifacts",
        "rules_rituals",
        "division_of_labor",
        "domain_vocabulary",
        "implementation_concepts_to_hide",
        "diagnostic_disclosure"
      ],
      "properties": {
        "activity_supported": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "objective": { "type": "string" },
        "outcomes": { "type": "array", "items": { "type": "string" } },
        "existing_tools_artifacts": { "type": "array", "items": { "type": "string" } },
        "rules_rituals": { "type": "array", "items": { "type": "string" } },
        "division_of_labor": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["participant", "responsibility"],
            "properties": {
              "participant": { "type": "string" },
              "responsibility": { "type": "string" }
            }
          }
        },
        "domain_vocabulary": { "type": "array", "items": { "type": "string" } },
        "implementation_concepts_to_hide": { "type": "array", "items": { "type": "string" } },
        "diagnostic_disclosure": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["concept", "reveal_when"],
            "properties": {
              "concept": { "type": "string" },
              "reveal_when": { "type": "string" }
            }
          }
        }
      }
    },
    "interaction_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_is_trying_to",
        "user_thinks_about_work_as",
        "user_does_not_think_about_work_as",
        "primary_decisions",
        "make_easy",
        "make_harder",
        "state_changes",
        "leave_screen_knowing_or_done"
      ],
      "properties": {
        "user_is_trying_to": { "type": "string" },
        "user_thinks_about_work_as": { "type": "string" },
        "user_does_not_think_about_work_as": { "type": "string" },
        "primary_decisions": { "type": "array", "items": { "type": "string" } },
        "make_easy": { "type": "array", "items": { "type": "string" } },
        "make_harder": { "type": "array", "items": { "type": "string" } },
        "state_changes": { "type": "array", "items": { "type": "string" } },
        "leave_screen_knowing_or_done": { "type": "array", "items": { "type": "string" } }
      }
    },
    "disclosure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_ui_can_show",
        "product_ui_must_not_show",
        "diagnostic_contexts",
        "term_replacements"
      ],
      "properties": {
        "product_ui_can_show": { "type": "array", "items": { "type": "string" } },
        "product_ui_must_not_show": { "type": "array", "items": { "type": "string" } },
        "diagnostic_contexts": { "type": "array", "items": { "type": "string" } },
        "term_replacements": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["avoid", "prefer"],
            "properties": {
              "avoid": { "type": "string" },
              "prefer": { "type": "string" }
            }
          }
        }
      }
    },
    "implementation_contract": {
      "$ref": "#/$defs/implementationContract"
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_pass", "failure_signals"],
      "properties": {
        "must_pass": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "surfaceType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "purpose",
        "applies_when_most_true",
        "do_not_use_when"
      ],
      "properties": {
        "label": { "type": "string" },
        "purpose": { "type": "string" },
        "applies_when_most_true": { "type": "array", "items": { "type": "string" } },
        "do_not_use_when": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visualTokenRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "families", "usage"],
      "properties": {
        "role": { "type": "string" },
        "families": { "type": "array", "items": { "type": "string" } },
        "usage": { "type": "string" }
      }
    },
    "fontRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "stack", "usage"],
      "properties": {
        "role": { "type": "string" },
        "stack": { "type": "string" },
        "usage": { "type": "string" },
        "feature_settings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "iconCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "library",
        "package",
        "version",
        "icon_count",
        "license",
        "notice",
        "style_system",
        "style_attributes",
        "mcp_tools",
        "default_include_svg"
      ],
      "properties": {
        "source": { "type": "string" },
        "library": { "type": "string" },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "icon_count": { "type": "number", "minimum": 1 },
        "license": { "type": "string" },
        "notice": { "type": "string" },
        "style_system": { "type": "string" },
        "style_attributes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "mcp_tools": { "type": "array", "items": { "type": "string" } },
        "default_include_svg": { "type": "boolean" }
      }
    },
    "iconSelectionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_library",
        "selection_flow",
        "semantic_guidance",
        "accessibility_guidance",
        "failure_signals"
      ],
      "properties": {
        "source_library": { "type": "string" },
        "selection_flow": { "type": "array", "items": { "type": "string" } },
        "semantic_guidance": { "type": "string" },
        "accessibility_guidance": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cssCustomProperty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "family", "value", "usage"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "family": { "type": "string" },
        "value": { "type": "string" },
        "usage": { "type": "string" }
      }
    },
    "appearancePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported_modes",
        "default_mode",
        "visible_toggle_default",
        "mode_resolution",
        "visible_toggle_policy",
        "persistence_policy",
        "css_strategy"
      ],
      "properties": {
        "supported_modes": { "type": "array", "items": { "type": "string" } },
        "default_mode": { "type": "string" },
        "visible_toggle_default": { "type": "boolean" },
        "mode_resolution": { "type": "string" },
        "visible_toggle_policy": { "type": "string" },
        "persistence_policy": { "type": "string" },
        "css_strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default_selector", "dark_query", "dark_selector"],
          "properties": {
            "default_selector": { "type": "string" },
            "dark_query": { "type": "string" },
            "dark_selector": { "type": "string" }
          }
        }
      }
    },
    "appearanceTokenSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "color_scheme", "css_custom_properties"],
      "properties": {
        "mode": { "type": "string" },
        "color_scheme": { "type": "string" },
        "css_custom_properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/cssCustomProperty" }
        }
      }
    },
    "componentContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "purpose",
        "use_when",
        "avoid_when",
        "anatomy",
        "required_states",
        "token_bindings",
        "accessibility_checks",
        "review_checks",
        "failure_signals"
      ],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "purpose": { "type": "string" },
        "use_when": { "type": "array", "items": { "type": "string" } },
        "avoid_when": { "type": "array", "items": { "type": "string" } },
        "anatomy": { "type": "array", "items": { "type": "string" } },
        "required_states": { "type": "array", "items": { "type": "string" } },
        "token_bindings": { "type": "array", "items": { "type": "string" } },
        "accessibility_checks": { "type": "array", "items": { "type": "string" } },
        "review_checks": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "patternContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "surface_type",
        "purpose",
        "required_regions",
        "expected_controls",
        "completion_or_handoff",
        "disclosure_boundary",
        "accessibility_expectations",
        "failure_signals"
      ],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "surface_type": { "type": "string" },
        "purpose": { "type": "string" },
        "required_regions": { "type": "array", "items": { "type": "string" } },
        "expected_controls": { "type": "array", "items": { "type": "string" } },
        "completion_or_handoff": { "type": "string" },
        "disclosure_boundary": { "type": "string" },
        "accessibility_expectations": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "designSystemSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "mode",
        "name",
        "package",
        "definition_point",
        "required_authorities",
        "fallback_policy",
        "provenance_required",
        "source_exports",
        "token_prefixes",
        "icon_catalog",
        "renderer_components",
        "component_contract_source",
        "provenance_rules"
      ],
      "properties": {
        "id": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["judgmentkit_default", "external_design_system"]
        },
        "name": { "type": "string" },
        "package": { "type": "string" },
        "definition_point": { "type": "string" },
        "required_authorities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tokens", "fonts", "icons", "components"]
          }
        },
        "fallback_policy": {
          "type": "string",
          "const": "fail_incomplete"
        },
        "provenance_required": { "type": "boolean" },
        "source_exports": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          }
        },
        "token_prefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "icon_catalog": { "$ref": "#/$defs/iconCatalog" },
        "renderer_components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "component_contract_source": { "type": "string" },
        "provenance_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "implementationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "purpose",
        "authority_order",
        "approved_primitives",
        "primitive_rules",
        "state_coverage",
        "static_enforcement",
        "browser_qa",
        "default_ai_native_design_system",
        "iteration_policy",
        "design_system_source",
        "visual_token_adapter",
        "visual_asset_policy",
        "accessibility_policy",
        "repo_scaffold_outputs",
        "failure_signals"
      ],
      "properties": {
        "id": { "type": "string" },
        "purpose": { "type": "string" },
        "authority_order": { "type": "array", "items": { "type": "string" } },
        "approved_primitives": { "type": "array", "items": { "type": "string" } },
        "primitive_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["primitive", "required"],
            "properties": {
              "primitive": { "type": "string" },
              "required": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "state_coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_states", "required_evidence"],
          "properties": {
            "required_states": { "type": "array", "items": { "type": "string" } },
            "required_evidence": { "type": "array", "items": { "type": "string" } }
          }
        },
        "static_enforcement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["default_rules"],
          "properties": {
            "default_rules": { "type": "array", "items": { "type": "string" } }
          }
        },
        "browser_qa": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "checks"],
          "properties": {
            "required": { "type": "boolean" },
            "checks": { "type": "array", "items": { "type": "string" } }
          }
        },
        "default_ai_native_design_system": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "mode",
            "purpose",
            "primitive_defaults",
            "surface_patterns",
            "state_rules",
            "component_contracts",
            "pattern_contracts",
            "action_boundaries",
            "data_visibility",
            "accessibility",
            "evidence_gates",
            "adapter_boundary"
          ],
          "properties": {
            "id": { "type": "string" },
            "mode": { "type": "string" },
            "purpose": { "type": "string" },
            "primitive_defaults": { "type": "array", "items": { "type": "string" } },
            "surface_patterns": { "type": "array", "items": { "type": "string" } },
            "state_rules": { "type": "array", "items": { "type": "string" } },
            "component_contracts": {
              "type": "array",
              "items": { "$ref": "#/$defs/componentContract" }
            },
            "pattern_contracts": {
              "type": "array",
              "items": { "$ref": "#/$defs/patternContract" }
            },
            "action_boundaries": {
              "type": "object",
              "additionalProperties": false,
              "required": ["required", "risky_action_terms", "failure_signals"],
              "properties": {
                "required": { "type": "array", "items": { "type": "string" } },
                "risky_action_terms": { "type": "array", "items": { "type": "string" } },
                "failure_signals": { "type": "array", "items": { "type": "string" } }
              }
            },
            "data_visibility": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "primary_data_roles",
                "diagnostic_only_terms",
                "allowed_diagnostic_contexts",
                "failure_signals"
              ],
              "properties": {
                "primary_data_roles": { "type": "array", "items": { "type": "string" } },
                "diagnostic_only_terms": { "type": "array", "items": { "type": "string" } },
                "allowed_diagnostic_contexts": { "type": "array", "items": { "type": "string" } },
                "failure_signals": { "type": "array", "items": { "type": "string" } }
              }
            },
            "accessibility": {
              "type": "object",
              "additionalProperties": false,
              "required": ["baseline", "evidence_source"],
              "properties": {
                "baseline": { "type": "string" },
                "evidence_source": { "type": "string" }
              }
            },
            "evidence_gates": { "type": "array", "items": { "type": "string" } },
            "adapter_boundary": {
              "type": "object",
              "additionalProperties": false,
              "required": ["visual_token_adapter", "renderer_package"],
              "properties": {
                "visual_token_adapter": { "type": "string" },
                "renderer_package": { "type": "string" }
              }
            }
          }
        },
        "iteration_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "owner",
            "default_max_attempts",
            "loop",
            "pass_status",
            "failure_statuses",
            "judgmentkit_role"
          ],
          "properties": {
            "owner": { "type": "string" },
            "default_max_attempts": { "type": "number", "minimum": 1 },
            "loop": { "type": "array", "items": { "type": "string" } },
            "pass_status": { "type": "string" },
            "failure_statuses": { "type": "array", "items": { "type": "string" } },
            "judgmentkit_role": { "type": "string" }
          }
        },
        "design_system_source": { "$ref": "#/$defs/designSystemSource" },
        "local_component_authority": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "enforcement",
            "families",
            "selector_boundary",
            "token_boundary",
            "computed_style_evidence"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["none", "repo_local"]
            },
            "enforcement": {
              "type": "string",
              "enum": ["optional", "required"]
            },
            "families": {
              "type": "array",
              "items": { "type": "string" }
            },
            "selector_boundary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "allowed",
                "component_selector_examples",
                "layout_only_declarations",
                "blocked_visual_identity_declarations"
              ],
              "properties": {
                "allowed": { "type": "array", "items": { "type": "string" } },
                "component_selector_examples": { "type": "array", "items": { "type": "string" } },
                "layout_only_declarations": { "type": "array", "items": { "type": "string" } },
                "blocked_visual_identity_declarations": { "type": "array", "items": { "type": "string" } }
              }
            },
            "token_boundary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "direct_token_prefixes",
                "layout_token_exceptions",
                "rule"
              ],
              "properties": {
                "direct_token_prefixes": { "type": "array", "items": { "type": "string" } },
                "layout_token_exceptions": { "type": "array", "items": { "type": "string" } },
                "rule": { "type": "string" }
              }
            },
            "computed_style_evidence": {
              "type": "object",
              "additionalProperties": false,
              "required": ["required_when", "expectations"],
              "properties": {
                "required_when": { "type": "string" },
                "expectations": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "visual_token_adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "mode",
            "purpose",
            "token_families",
            "token_roles",
            "css_custom_properties",
            "appearance_policy",
            "appearance_token_sets",
            "semantic_roles",
            "font_roles",
            "font_rules",
            "icon_roles",
            "icon_catalog",
            "icon_selection_policy",
            "icon_rules",
            "adapter_rules",
            "evidence_expectations",
            "deferred_renderer",
            "failure_signals"
          ],
          "properties": {
            "id": { "type": "string" },
            "mode": { "type": "string" },
            "purpose": { "type": "string" },
            "token_families": { "type": "array", "items": { "type": "string" } },
            "token_roles": { "type": "array", "items": { "$ref": "#/$defs/visualTokenRole" } },
            "css_custom_properties": {
              "type": "array",
              "items": { "$ref": "#/$defs/cssCustomProperty" }
            },
            "appearance_policy": { "$ref": "#/$defs/appearancePolicy" },
            "appearance_token_sets": {
              "type": "array",
              "items": { "$ref": "#/$defs/appearanceTokenSet" }
            },
            "semantic_roles": { "type": "array", "items": { "type": "string" } },
            "font_roles": { "type": "array", "items": { "$ref": "#/$defs/fontRole" } },
            "font_rules": { "type": "array", "items": { "type": "string" } },
            "icon_roles": { "type": "array", "items": { "type": "string" } },
            "icon_catalog": { "$ref": "#/$defs/iconCatalog" },
            "icon_selection_policy": { "$ref": "#/$defs/iconSelectionPolicy" },
            "icon_rules": { "type": "array", "items": { "type": "string" } },
            "adapter_rules": { "type": "array", "items": { "type": "string" } },
            "evidence_expectations": { "type": "array", "items": { "type": "string" } },
            "deferred_renderer": {
              "type": "object",
              "additionalProperties": false,
              "required": ["renderer_package", "component_package", "catalog_compiler"],
              "properties": {
                "renderer_package": { "type": "string" },
                "component_package": { "type": "string" },
                "catalog_compiler": { "type": "string" }
              }
            },
            "failure_signals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "visual_asset_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applies_when",
            "preferred_paths",
            "deterministic_safe_uses",
            "failure_signals"
          ],
          "properties": {
            "applies_when": { "type": "array", "items": { "type": "string" } },
            "preferred_paths": { "type": "array", "items": { "type": "string" } },
            "deterministic_safe_uses": { "type": "array", "items": { "type": "string" } },
            "failure_signals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "accessibility_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "standards_profile",
            "contrast_targets",
            "rendered_background_readability",
            "required_evidence",
            "conditional_evidence",
            "contracts",
            "evidence_model",
            "failure_signals"
          ],
          "properties": {
            "standards_profile": {
              "type": "object",
              "additionalProperties": false,
              "required": ["baseline", "evidence_model_version", "sources"],
              "properties": {
                "baseline": { "type": "string" },
                "evidence_model_version": { "type": "string" },
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "label", "level", "url"],
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "level": { "type": "string" },
                      "url": { "type": "string" }
                    }
                  }
                }
              }
            },
            "contrast_targets": {
              "type": "object",
              "additionalProperties": false,
              "required": ["normal_text_min_ratio", "large_text_min_ratio", "non_text_min_ratio"],
              "properties": {
                "normal_text_min_ratio": { "type": "number", "minimum": 1 },
                "large_text_min_ratio": { "type": "number", "minimum": 1 },
                "non_text_min_ratio": { "type": "number", "minimum": 1 }
              }
            },
            "rendered_background_readability": {
              "type": "object",
              "additionalProperties": false,
              "required": ["applies_to", "requirement"],
              "properties": {
                "applies_to": { "type": "array", "items": { "type": "string" } },
                "requirement": { "type": "string" }
              }
            },
            "required_evidence": { "type": "array", "items": { "type": "string" } },
            "conditional_evidence": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["applies_when", "wcag_criteria"],
                "properties": {
                  "applies_when": { "type": "array", "items": { "type": "string" } },
                  "wcag_criteria": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "contracts": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["requirements", "evidence"],
                "properties": {
                  "requirements": { "type": "array", "items": { "type": "string" } },
                  "evidence": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "evidence_model": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "entry_shape",
                "accepted_statuses",
                "not_applicable_requires_rationale",
                "automated_only_insufficient",
                "core_required",
                "conditional_required"
              ],
              "properties": {
                "entry_shape": { "type": "array", "items": { "type": "string" } },
                "accepted_statuses": { "type": "array", "items": { "type": "string" } },
                "not_applicable_requires_rationale": { "type": "boolean" },
                "automated_only_insufficient": { "type": "boolean" },
                "core_required": { "type": "array", "items": { "type": "string" } },
                "conditional_required": { "type": "array", "items": { "type": "string" } }
              }
            },
            "failure_signals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "repo_scaffold_outputs": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
